generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
}

model User {
  id         String   @id @default(cuid())
  clerkId    String   @unique
  email      String   @unique
  name       String?
  plan       Plan     @default(FREE)
  onboarded  Boolean  @default(false)
  createdAt  DateTime @default(now())

  habits  Habit[]
  reports WeeklyReport[]
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  raters  Rater[]
  ratings Rating[]
}

model Rater {
  id        String   @id @default(cuid())
  habitId   String
  email     String
  token     String   @unique
  nickname  String?
  createdAt DateTime @default(now())

  habit   Habit    @relation(fields: [habitId], references: [id])
  ratings Rating[]
}

model Rating {
  id        String   @id @default(cuid())
  habitId   String
  raterId   String?
  weekStart DateTime
  score     Int
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id])
  rater Rater? @relation(fields: [raterId], references: [id])
}

model WeeklyReport {
  id          String   @id @default(cuid())
  userId      String
  weekStart   DateTime
  selfScore   Float
  circleScore Float
  gapScore    Float
  aiSummary   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}