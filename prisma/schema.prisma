generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
}

model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique
  email            String    @unique
  name             String?
  plan             Plan      @default(FREE)
  onboarded        Boolean   @default(false)
  stripeCustomerId String?   @unique
  stripePriceId    String?
  stripeSubId      String?
  aiSummaryCount   Int       @default(0)
  pseudonym        String?   @unique
  podDailyCount    Int       @default(0)
  podMonthlyCount  Int       @default(0)
  podStreak        Int       @default(0)
  lastPodDate      DateTime?
  createdAt        DateTime  @default(now())

  habits     Habit[]
  reports    WeeklyReport[]
  podSignups PodSignup[]
  podMembers PodMember[]
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  raters  Rater[]
  ratings Rating[]
}

model Rater {
  id        String   @id @default(cuid())
  habitId   String
  email     String
  token     String   @unique
  nickname  String?
  createdAt DateTime @default(now())

  habit   Habit    @relation(fields: [habitId], references: [id])
  ratings Rating[]
}

model Rating {
  id        String   @id @default(cuid())
  habitId   String
  raterId   String?
  weekStart DateTime
  score     Int
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id])
  rater Rater? @relation(fields: [raterId], references: [id])
}

model WeeklyReport {
  id          String   @id @default(cuid())
  userId      String
  weekStart   DateTime
  selfScore   Float
  circleScore Float
  gapScore    Float
  aiSummary   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum PodCategory {
  STUDY
  CODING
  WRITING
  READING
  DESIGN
  JOB_HUNT
  ADMIN
  LEARNING
  BUSINESS
  DEEP_WORK
}

enum PodStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

model Pod {
  id            String      @id @default(cuid())
  scheduledFor  DateTime
  category      PodCategory?
  status        PodStatus   @default(SCHEDULED)
  dailyRoomUrl  String?
  dailyRoomName String?
  maxMembers    Int         @default(5)
  duration      Int         @default(25)
  startedAt     DateTime?
  endsAt        DateTime?
  createdAt     DateTime    @default(now())

  signups PodSignup[]
  members PodMember[]
}

model PodSignup {
  id         String      @id @default(cuid())
  podId      String
  userId     String
  category   PodCategory
  cancelledAt DateTime?
  createdAt  DateTime    @default(now())

  pod  Pod  @relation(fields: [podId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model PodMember {
  id          String   @id @default(cuid())
  podId       String
  userId      String
  task        String?
  joinedAt    DateTime @default(now())
  completedAt DateTime?
  strikes     Int      @default(0)

  pod  Pod  @relation(fields: [podId], references: [id])
  user User @relation(fields: [userId], references: [id])
}